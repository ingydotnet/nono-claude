#!/usr/bin/env bash

set -euo pipefail

main() (
  setup "$@"

  for arg; do
    if [[ $arg == --update ]]; then
      do-update
      exit
    elif [[ $arg == --config ]]; then
      run "${EDITOR:-vim}" "$project_config"
      exit
    elif [[ $arg == --claude-md ]]; then
      do-claude-md
      exit
    fi
  done

  export NONO_CLAUDE_OPTS_CLAUDE=$*

  ys=$(make -f "$root/Makefile" ys)
  "$ys" -x "$root/util/config-yaml-to-mk" \
    "$global_config" "$project_config" > config.mk

  make -f "$root/Makefile" claude-nono
)

setup() {
  [[ ${NONO_CLAUDE_ROOT-} ]] ||
    die "NONO_CLAUDE_ROOT not set" \
        "Try: source /path/to/nono-claude/.rc"

  makefile=$NONO_CLAUDE_ROOT/Makefile
  [[ -e $makefile ]] ||
    die "NONO_CLAUDE_ROOT='$NONO_CLAUDE_ROOT' is broken"

  [[ $PWD != "$HOME" ]] ||
    die "Don't run nono-claude in your HOME directory"

  root=$NONO_CLAUDE_ROOT
  share=$root/share
  cwd=$(pwd -P)
  base=$(get-project-base)
  export NONO_CLAUDE_BASE=$base

  project_config_dir=$root/config/${base#/}
  [[ -d $project_config_dir ]] ||
    mkdir -p "$project_config_dir"

  claude_md_file=$project_config_dir/CLAUDE.md
  claude_md_link=$cwd/CLAUDE.md

  template_config=$share/config.yaml
  global_config=$root/config.yaml
  project_config=$project_config_dir/config.yaml

  [[ -e $project_config ]] ||
    cp "$template_config" "$project_config"

  [[ -e $global_config ]] ||
    cp "$template_config" "$global_config"
}

do-update() (
  set -x
  git -C "$root" pull
  rm -fr "$root/makes"
  rm -fr "$root/local"
)

do-claude-md() (
  if [[ -f $claude_md_link && ! -L $claude_md_link ]]; then
    if ! git ls-files --error-unmatch "$claude_md_link" &>/dev/null; then
      run mv "$claude_md_link" "$claude_md_file"
      run ln -fs "$claude_md_file" "$claude_md_link"
    fi
  fi
)

get-project-base() (
  if ! common=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null); then
    pwd -P
    return
  fi
  # Non-bare repos always have common dir named `.git` (inside the
  # project). A bare repo is its own project dir. Check `core.bare` as
  # the primary signal — `git rev-parse --is-bare-repository` answers
  # for the current worktree, which is always false from a linked
  # worktree of a bare repo — and fall back to the basename heuristic
  # for bare repos missing the setting.
  bare=$(git config --file="$common/config" --get core.bare 2>/dev/null || true)
  if [[ $bare == true || $(basename "$common") != .git ]]; then
    echo "$common"
  else
    (cd "$common/.." && pwd -P)
  fi
)

run() ( set -x; "$@" )

die() { printf "%s\n" Error: "$@" >&2; exit 1; }

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  main "$@"
fi
