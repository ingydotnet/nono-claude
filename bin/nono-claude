#!/usr/bin/env bash

set -euo pipefail

main() (
  setup "$@"

  if $update; then
    do-update
    exit
  fi

  if $config; then
    run "${EDITOR:-vim}" "$nono_mk_file"
    exit
  fi

  if $claude_md; then
    do-claude-md
    exit
  fi

  export NONO_CLAUDE_OPTS_CLAUDE=${args[*]}

  make -f "$root/Makefile" claude-nono
)

setup() {
  [[ ${NONO_CLAUDE_ROOT-} ]] ||
    die "NONO_CLAUDE_ROOT not set" \
        "Try: source /path/to/nono-claude/.rc"

  makefile=$NONO_CLAUDE_ROOT/Makefile
  [[ -e $makefile ]] ||
    die "NONO_CLAUDE_ROOT='$NONO_CLAUDE_ROOT' is broken"

  [[ $PWD != "$HOME" ]] ||
    die "Don't run nono-claude in your HOME directory"

  root=$NONO_CLAUDE_ROOT
  share=$root/share
  base=$(pwd -P)
  args=()
  update=false
  config=false
  claude_md=false

  local arg
  for arg; do
    if [[ $arg == --update ]]; then
      update=true
    elif [[ $arg == --config ]]; then
      config=true
    elif [[ $arg == --claude-md ]]; then
      claude_md=true
    else
      args+=("$arg")
    fi
  done

  config_dir=$root/config/${base#/}
  [[ -d $config_dir ]] || mkdir -p "$config_dir"

  claude_md_file=$config_dir/CLAUDE.md
  claude_md_link=$base/CLAUDE.md

  nono_mk_file=$config_dir/NONO.mk

  [[ -e $nono_mk_file ]] ||
    cp "$share/NONO.mk" "$nono_mk_file"

  [[ -e $root/NONO.mk ]] ||
    cp "$share/NONO.mk" "$root/NONO.mk"
}

do-update() (
  set -x
  git -C "$root" pull
  rm -fr "$root/makes"
  rm -fr "$root/local"
)

do-claude-md() (
  if [[ -f $claude_md_link && ! -L $claude_md_link ]]; then
    if ! git ls-files --error-unmatch "$claude_md_link" &>/dev/null; then
      run mv "$claude_md_link" "$claude_md_file"
      run ln -fs "$claude_md_file" "$claude_md_link"
    fi
  fi
)

run() ( set -x; "$@" )

die() { printf "%s\n" Error: "$@" >&2; exit 1; }

main "$@"
